{
  "version": 2,
  "builds": [
    {
      "src": "api/scraper.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/node-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/scrape", "dest": "/api/scraper.py" },
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}
